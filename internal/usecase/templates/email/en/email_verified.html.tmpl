<!DOCTYPE html>
<html>
  <body style="margin:0;background:#eef2ff;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Ubuntu,sans-serif;">
    <div style="max-width:640px;margin:0 auto;padding:28px 16px;">
      <div style="background:linear-gradient(135deg,#0f172a,#1d4ed8);border-radius:18px;padding:24px 24px 18px;">
        <img src="cid:logo.png" alt="Logo" style="height:44px;width:auto;display:block;margin-bottom:14px;">
        <div style="font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:#bfdbfe;">Football Manager</div>
        <div style="margin-top:8px;font-size:28px;font-weight:800;color:#ffffff;">{{.Subject}}</div>
      </div>
      <div style="background:#ffffff;border-radius:18px;padding:24px;margin-top:14px;">
        <p style="margin:0 0 14px;color:#2e3c66;">Hi {{.DisplayName}}, your account is ready.</p>
        <h2 style="margin:0;color:#111a3d;">You can sign in now</h2>
      </div>
      <div style="padding:14px 6px 0;color:#6b7280;font-size:12px;">Automated message. Please do not reply.</div>
    </div>
  </body>
</html>
